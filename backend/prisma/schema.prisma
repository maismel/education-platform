generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                String       @id @default(uuid())
  email             String       @unique
  password          String

  firstName         String?
  lastName          String?
  avatarUrl         String?
  bio               String?

  role              Role

  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  
  attendanceRecords Attendance[] @relation("StudentAttendance")
  courses           Course[]
  enrollments       Enrollment[]
  gradedSubmissions Grade[]      @relation("TeacherGrades")
  uploadedMaterials Material[]   @relation("UploadedMaterials")
  submissions       Submission[] @relation("StudentSubmissions")
}

model Course {
  id          String       @id @default(uuid())
  title       String
  description String
  imageUrl    String?
  teacherId   String
  updatedAt   DateTime     @updatedAt
  createdAt   DateTime     @default(now())
  teacher     User         @relation(fields: [teacherId], references: [id])
  enrollments Enrollment[]
  lessons     Lesson[]
}

model Enrollment {
  id        String   @id @default(uuid())
  studentId String
  courseId  String
  createdAt DateTime @default(now())
  course    Course   @relation(fields: [courseId], references: [id])
  student   User     @relation(fields: [studentId], references: [id])
}

model Lesson {
  id                String       @id @default(uuid())
  courseId          String
  title             String
  description       String?
  startsAt          DateTime
  endsAt            DateTime
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  attendanceRecords Attendance[]
  course            Course       @relation(fields: [courseId], references: [id])
  materials         Material[]
  submissions       Submission[]
}

model Material {
  id           String   @id @default(uuid())
  lessonId     String
  uploadedById String
  fileName     String?
  fileUrl      String?
  mimeType     String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  comment      String?
  lesson       Lesson   @relation(fields: [lessonId], references: [id])
  uploadedBy   User     @relation("UploadedMaterials", fields: [uploadedById], references: [id])
}

model Submission {
  id          String   @id @default(uuid())
  lessonId    String
  studentId   String
  fileName    String?
  fileUrl     String?
  mimeType    String?
  comment     String?
  submittedAt DateTime @default(now())
  status      Status
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  grade       Grade?
  lesson      Lesson   @relation(fields: [lessonId], references: [id])
  student     User     @relation("StudentSubmissions", fields: [studentId], references: [id])
}

model Grade {
  id           String     @id @default(uuid())
  submissionId String     @unique
  teacherId    String
  score        Int
  feedback     String?
  gradedAt     DateTime   @default(now())
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  submission   Submission @relation(fields: [submissionId], references: [id])
  teacher      User       @relation("TeacherGrades", fields: [teacherId], references: [id])
}

model Attendance {
  id        String           @id @default(uuid())
  lessonId  String
  studentId String
  status    AttendanceStatus
  comment   String?
  createdAt DateTime         @default(now())
  lesson    Lesson           @relation(fields: [lessonId], references: [id])
  student   User             @relation("StudentAttendance", fields: [studentId], references: [id])
}

enum Role {
  STUDENT
  TEACHER
  ADMIN
}

enum Status {
  PENDING
  REVIEWED
  LATE
  REJECTED
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  EXCUSED
}
